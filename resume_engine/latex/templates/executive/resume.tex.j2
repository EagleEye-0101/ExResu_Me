\documentclass[10pt,letterpaper]{article}
\usepackage[margin=0.55in]{geometry}
\usepackage{titlesec}
\usepackage{enumitem}
\usepackage{xcolor}
\usepackage[hidelinks]{hyperref}
\definecolor{HeaderBg}{HTML}{1E3A5F}
\definecolor{HeaderText}{HTML}{FFFFFF}
\definecolor{Accent}{HTML}{1E3A5F}
\pagestyle{empty}
\setlength{\parindent}{0pt}
\titleformat{\section}{\color{Accent}\bfseries\large}{}{0em}{}[\titlerule]
\titlespacing*{\section}{0pt}{10pt}{5pt}
\begin{document}
\noindent\colorbox{HeaderBg}{\begin{minipage}{ {{ header_width }} }
\vspace{10pt}
\begin{center}
{\color{HeaderText}\bfseries\LARGE {{ resume.full_name | tex }}}\\[6pt]
{\color{HeaderText}\small {{ contact_line }}}
{% if resume.headline %}\\[4pt]{\color{HeaderText}\itshape {{ resume.headline | tex }}}{% endif %}
\end{center}
\vspace{10pt}
\end{minipage}}
\vspace{8pt}
{% if resume.summary %}
\section{Executive Summary}
{{ resume.summary | tex }}
{% endif %}
{% if resume.experience %}
\section{Professional Experience}
{% for exp in resume.experience %}
\textbf{ {{ exp.title | tex }} } \hfill {{ exp.start_date | tex }} -- {{ (exp.end_date or 'Present') | tex }} \\
\textit{ {{ exp.company | tex }}{% if exp.location %} \textbar\ {{ exp.location | tex }}{% endif %} } \\
\begin{itemize}[leftmargin=*, nosep, topsep=2pt, itemsep=0pt]
{% for b in exp.bullets %}\item {{ b | tex }}
{% endfor %}\end{itemize}
{% endfor %}
{% endif %}
{% if resume.education %}
\section{Education}
{% for edu in resume.education %}
\textbf{ {{ edu.institution | tex }} } \hfill {{ edu.graduation_date | tex }} \\
{{ edu.degree | tex }}{% if edu.field %} — {{ edu.field | tex }}{% endif %}{% if edu.gpa %} \textbar\ GPA {{ edu.gpa | tex }}{% endif %} \\
{% endfor %}
{% endif %}
{% if skill_groups %}
\section{Core Competencies}
{% for g in skill_groups %}\textbf{ {{ g.label | tex }}: } {{ g.skills | join(', ') | tex }} \\
{% endfor %}
{% endif %}
{% if resume.projects %}
\section{Key Projects}
{% for p in resume.projects %}
\textbf{ {{ p.name | tex }} }{% if p.context %} ({{ p.context | tex }}){% endif %} \\
\begin{itemize}[leftmargin=*, nosep, topsep=1pt]
{% for b in p.bullets %}\item {{ b | tex }}
{% endfor %}\end{itemize}
{% endfor %}
{% endif %}
{% if resume.certifications %}
\section{Certifications}
{% for c in resume.certifications %}{{ c.name | tex }}{% if c.issuer %} — {{ c.issuer | tex }}{% endif %}{% if c.date %} ({{ c.date | tex }}){% endif %} \\
{% endfor %}
{% endif %}
\end{document}
