# AI Providers (set at least one for generation)
DEFAULT_AI_PROVIDER=ollama

# Ollama (local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Anthropic (optional)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-20241022

# Google AI Studio — free API key at https://aistudio.google.com/apikey
# (same key as Gemini; use provider "google_ai_studio" or "gemini" in the app)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3-flash-preview
# DEFAULT_AI_PROVIDER=google_ai_studio

# OpenRouter (optional unified gateway)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini

# API / Database
DATABASE_URL=sqlite:///./data/resume_builder.db
API_HOST=127.0.0.1
API_PORT=8000
EXPORT_DIR=./exports

# LaTeX editor (Tectonic recommended: https://tectonic-typesetting.github.io/)
LATEX_COMPILER=tectonic
TECTONIC_PATH=
LATEX_COMPILE_TIMEOUT=30
