{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ATS Resume Builder",
  "version": "0.1.0",
  "identifier": "com.resumebuilder.app",
  "build": {
    "beforeDevCommand": "cd ../web && npm run dev",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "cd ../web && npm run build",
    "frontendDist": "../web/out"
  },
  "app": {
    "windows": [
      {
        "title": "ATS Resume Builder",
        "width": 1200,
        "height": 800,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  },
  "plugins": {}
}
